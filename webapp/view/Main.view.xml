<mvc:View
	controllerName="uxc.integration.controller.Main"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:tnt="sap.tnt"
	xmlns:webc="@ui5/webcomponents/dist"
	xmlns:webcf="@ui5/webcomponents-fiori/dist"
	core:require="{
		formatter: 'uxc/integration/model/formatter',
		menu2: '@ui5/webcomponents-icons/dist/menu2',
		sysHelp: '@ui5/webcomponents-icons/dist/sys-help',
		da: '@ui5/webcomponents-icons/dist/da'
	}">
	<tnt:ToolPage>
		<tnt:header>
			<webcf:ShellBar
				primaryTitle="VEGA CRM"
				showNotifications="true"
				notificationsCount="4"
				showProductSwitch="true"
				showSearchField="true"
			>
				<webcf:startButton>
					<webc:Button icon="menu2" tooltip="Toggle Side Navigation" />
				</webcf:startButton>

				<webcf:logo>
					<Image src="../images/SAP_Logo.svg" alt="Logo" />
				</webcf:logo>

				<webcf:assistant>
					<webc:ToggleButton icon="da" />
				</webcf:assistant>

				<webcf:ShellBarItem icon="sys-help" />

				<webcf:profile>
					<webc:Avatar>
						<Image src="../images/Avatar.svg" alt="Avatar" />
					</webc:Avatar>
				</webcf:profile>

			</webcf:ShellBar>
		</tnt:header>
	</tnt:ToolPage>

</mvc:View>
